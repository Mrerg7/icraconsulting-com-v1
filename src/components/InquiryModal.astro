---
import { SITE_NAME, ACQUISITION_EMAIL } from '../lib/constants';
---

<div id="inquiry-modal" class="hidden fixed inset-0 bg-black/60 backdrop-blur-sm z-[100] flex items-center justify-center p-4" role="dialog" aria-modal="true" aria-labelledby="modal-title">
  <div class="bg-white w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden">
    <!-- Modal Header -->
    <div class="px-7 pt-6 pb-4 bg-slate-900 text-white flex justify-between items-center">
      <div>
        <div id="modal-title" class="font-semibold text-xl tracking-tight">Acquire {SITE_NAME}</div>
        <div class="text-teal-400 text-sm">Confidential inquiry form</div>
      </div>
      <button id="modal-close-btn" class="text-white/60 hover:text-white w-9 h-9 flex items-center justify-center" aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <form id="inquiry-form" class="p-7 space-y-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-1.5" for="full-name">FULL NAME</label>
          <input type="text" id="full-name" name="full-name" required class="w-full border border-slate-200 focus:border-teal-500 outline-none px-4 py-3 rounded-2xl text-sm" placeholder="Morgan Quinn" autocomplete="name">
        </div>
        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-1.5" for="company">COMPANY / ORGANIZATION</label>
          <input type="text" id="company" name="company" class="w-full border border-slate-200 focus:border-teal-500 outline-none px-4 py-3 rounded-2xl text-sm" placeholder="Your Company or 'Individual'" autocomplete="organization">
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-1.5" for="email">EMAIL ADDRESS</label>
          <input type="email" id="email" name="email" required class="w-full border border-slate-200 focus:border-teal-500 outline-none px-4 py-3 rounded-2xl text-sm" placeholder="you@company.com" autocomplete="email">
        </div>
        <div>
          <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-1.5" for="phone">PHONE (OPTIONAL)</label>
          <input type="tel" id="phone" name="phone" class="w-full border border-slate-200 focus:border-teal-500 outline-none px-4 py-3 rounded-2xl text-sm" placeholder="(602) 555-0199" autocomplete="tel">
        </div>
      </div>

      <div>
        <label class="block text-xs font-semibold tracking-wider text-slate-500 mb-1.5" for="message">TELL US ABOUT YOUR INTEREST</label>
        <textarea id="message" name="message" rows="4" required class="w-full border border-slate-200 focus:border-teal-500 outline-none px-4 py-3.5 rounded-3xl text-sm resize-y min-h-[92px]" placeholder="I'm interested in acquiring icraconsulting.com to establish a professional ICRA consulting and advisory practice. My background is in..."></textarea>
      </div>

      <div class="pt-2">
        <button type="submit"
                class="w-full py-4 bg-teal-600 hover:bg-teal-700 active:bg-teal-800 transition-colors text-white font-semibold rounded-3xl flex items-center justify-center gap-x-2 text-base shadow-sm">
          <span>Submit Confidential Inquiry</span>
        </button>
        <p class="text-center text-[10px] text-slate-400 mt-3">We typically respond within 24 hours. All inquiries are kept strictly confidential.</p>
      </div>
    </form>
  </div>
</div>

<script>
  function showModal() {
    const modal = document.getElementById('inquiry-modal');
    if (modal) {
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      setTimeout(() => {
        document.getElementById('full-name')?.focus();
      }, 300);
    }
  }

  function hideModal() {
    const modal = document.getElementById('inquiry-modal');
    if (modal) {
      modal.classList.remove('flex');
      modal.classList.add('hidden');
    }
  }

  document.getElementById('modal-close-btn')?.addEventListener('click', hideModal);
  document.getElementById('inquiry-modal')?.addEventListener('click', (e) => {
    if (e.target === e.currentTarget) hideModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const modal = document.getElementById('inquiry-modal');
      if (modal && !modal.classList.contains('hidden')) {
        hideModal();
      }
    }
  });

  document.getElementById('inquiry-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.currentTarget as HTMLFormElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    if (!submitBtn) return;

    submitBtn.innerHTML = `<span class="flex items-center justify-center gap-x-2">
      <svg class="animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg><span>Submitting...</span></span>`;
    submitBtn.disabled = true;

    setTimeout(() => {
      form.innerHTML = `<div class="py-8 text-center">
        <div class="mx-auto w-16 h-16 bg-emerald-100 text-emerald-600 rounded-full flex items-center justify-center mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h3 class="font-semibold text-2xl tracking-tight text-slate-900 mb-2">Inquiry Received</h3>
        <p class="text-slate-600 max-w-xs mx-auto">Thank you. A member of our acquisition team will contact you within 24 hours to discuss next steps confidentially.</p>
        <button type="button" class="mt-8 px-8 py-3 text-sm font-semibold border border-slate-200 hover:bg-slate-50 rounded-3xl transition-colors" id="close-success-btn">Close Window</button>
      </div>`;

      document.getElementById('close-success-btn')?.addEventListener('click', hideModal);
    }, 1450);
  });

  // Expose for external triggers
  (window as any).showInquiryModal = showModal;
  (window as any).hideInquiryModal = hideModal;
</script>
