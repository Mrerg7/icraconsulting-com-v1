---
import { SITE_NAME } from '../lib/constants';
---

<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-screen-2xl mx-auto">
    <div class="px-6 md:px-8 py-4 md:py-5 flex items-center justify-between">
      <div class="flex items-center gap-x-3">
        <!-- Logo -->
        <a href="/" class="flex items-center gap-x-2.5" aria-label={`${SITE_NAME} home`}>
          <div class="w-8 h-8 md:w-9 md:h-9 bg-teal-600 rounded-2xl flex items-center justify-center shadow-inner" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 md:w-5 md:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.25">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
            </svg>
          </div>
          <div class="flex items-baseline">
            <span class="font-semibold tracking-tighter text-2xl md:text-3xl">icra</span>
            <span class="text-teal-600 font-semibold text-xl md:text-2xl">consulting.com</span>
          </div>
        </a>
        <div class="premium-badge ml-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-2.5 h-2.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M11.48 3.499a.562.562 0 011.04 0l2.395 5.228a.562.562 0 00.452.328l5.63.65a.562.562 0 01.317.971l-4.19 3.84a.562.562 0 00-.173.526l1.14 5.56a.562.562 0 01-.827.596l-4.9-2.797a.562.562 0 00-.548 0l-4.9 2.797a.562.562 0 01-.827-.596l1.14-5.56a.562.562 0 00-.173-.526l-4.19-3.84a.562.562 0 01.317-.971l5.63-.65a.562.562 0 00.452-.328l2.395-5.228z"/></svg>
          <span class="font-semibold tracking-[0.5px] text-[9px]">PREMIUM</span>
        </div>
      </div>

      <!-- Desktop Nav -->
      <div class="hidden md:flex items-center gap-x-8 text-sm font-medium">
        <a href="#opportunity" class="text-slate-600 hover:text-slate-900 transition-colors">Opportunity</a>
        <a href="#brand" class="text-slate-600 hover:text-slate-900 transition-colors">The Brand</a>
        <a href="#why-domain" class="text-slate-600 hover:text-slate-900 transition-colors">Why This Domain</a>
        <a href="#acquire" class="text-slate-600 hover:text-slate-900 transition-colors">Acquire</a>
      </div>

      <div class="flex items-center gap-x-3">
        <a href="#acquire"
           class="hidden md:inline-flex px-5 py-2.5 text-sm font-semibold bg-white border border-slate-300 hover:border-slate-400 text-slate-700 rounded-3xl transition-all active:scale-[0.985]">
          Make an Offer
        </a>
        <a href="#acquire"
           class="px-5 md:px-6 py-2.5 text-sm font-semibold bg-teal-600 hover:bg-teal-700 text-white rounded-3xl transition-all active:scale-[0.985] shadow-sm flex items-center gap-x-2">
          <span>Inquire Now</span>
        </a>

        <!-- Mobile menu toggle -->
        <button id="mobile-menu-btn" class="md:hidden w-10 h-10 flex items-center justify-center text-slate-600" aria-label="Toggle menu">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-200 px-6 py-4">
    <div class="flex flex-col gap-y-3 text-sm font-medium">
      <a href="#opportunity" class="py-1.5 text-slate-700">Opportunity</a>
      <a href="#brand" class="py-1.5 text-slate-700">The Brand</a>
      <a href="#why-domain" class="py-1.5 text-slate-700">Why This Domain</a>
      <a href="#acquire" class="py-1.5 text-slate-700">Acquire</a>
      <div class="pt-3 border-t flex flex-col gap-y-2.5">
        <a href="#acquire" class="w-full py-3 text-sm font-semibold bg-teal-600 text-white rounded-3xl text-center">Inquire Now</a>
      </div>
    </div>
  </div>
</nav>

<script>
  document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
    const menu = document.getElementById('mobile-menu');
    menu?.classList.toggle('hidden');
  });
</script>
